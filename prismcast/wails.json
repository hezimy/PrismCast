{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "PrismCast",
  "outputfilename": "PrismCast",
  "frontend": {
    "dir": "./frontend",
    "install": "npm install",
    "build": "npm run build",
    "dev": "npm run dev",
    "package": "npm run build"
  },
  "author": {
    "name": "hezimy",
    "email": ""
  },
  "info": {
    "companyName": "PrismCast",
    "productName": "PrismCast",
    "productVersion": "1.0.0",
    "copyright": "Copyright © 2025-2026 PrismCast Contributors",
    "comments": "A modern DLNA media renderer with beautiful UI"
  },
  "nsisType": "multiple",
  "obfuscated": false,
  "garbleargs": "",
  "ldflags": "-s -w",
  "bindings": {
    "ts_generation": {
      "outputType": "interfaces"
    }
  }
}
